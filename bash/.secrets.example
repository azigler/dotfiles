# Template for ~/.secrets — the REAL file lives at $HOME/.secrets and is
# NEVER committed. Copy this, fill in values, lock it down:
#
#   cp ~/dotfiles/bash/.secrets.example ~/.secrets
#   chmod 600 ~/.secrets
#
# ~/.bash_aliases sources ~/.secrets, so the exports below are available
# in every bash and zsh shell. Skills point here for any token they need
# rather than hardcoding it — one global place, never in source control.

# LinearB Marketing Fleet proxy — consumed by the /asana and /explore skills.
export FLEET_API_TOKEN=
