{
  "name": "newspaper",
  "description": "Classic broadsheet look for the daily digest. Georgia serif throughout, near-black ink, a restrained masthead-red accent for kickers/labels, an ink-blue for links, thin hairlines for items and a heavy black rule under the masthead + section heads. Denser type scale than editorial — reads like a printed front page.",
  "font": "Georgia",
  "palette": {
    "ink": "141414",
    "accent": "9E1B1B",
    "muted": "5A5A5A",
    "link": "1A4B8B",
    "rule": "D4D0C8",
    "ruleStrong": "141414"
  },
  "roles": {
    "kicker": {
      "size": 9,
      "bold": true,
      "color": "accent",
      "upper": true,
      "sa": 0,
      "sb": 3
    },
    "title": { "size": 30, "bold": true, "color": "ink", "sa": 1, "sb": 2 },
    "subtitle": {
      "size": 11.5,
      "italic": true,
      "color": "muted",
      "sa": 0,
      "sb": 2
    },
    "dateline": {
      "size": 9,
      "color": "muted",
      "upper": true,
      "sa": 1,
      "sb": 2
    },
    "intro": { "size": 11, "color": "ink", "sa": 4, "sb": 4 },
    "note": { "size": 9.5, "italic": true, "color": "muted", "sa": 0, "sb": 6 },
    "sectionRule": { "rule": "ruleStrong", "sa": 10, "sb": 4 },
    "itemRule": { "rule": "rule", "sa": 11, "sb": 7 },
    "heading": {
      "size": 13,
      "bold": true,
      "color": "accent",
      "upper": true,
      "sa": 14,
      "sb": 5
    },
    "itemTitle": { "size": 13, "bold": true, "color": "ink", "sa": 2, "sb": 2 },
    "itemNumber": { "size": 13, "bold": true, "color": "accent" },
    "link": { "size": 9, "color": "link", "underline": true, "sa": 0, "sb": 1 },
    "meta": { "size": 9, "color": "muted", "sa": 0, "sb": 3 },
    "label": {
      "size": 8,
      "bold": true,
      "color": "accent",
      "upper": true,
      "sa": 8,
      "sb": 1
    },
    "body": { "size": 10.5, "color": "ink", "sa": 0, "sb": 4 },
    "bullet": { "size": 10.5, "color": "ink", "bullet": true, "sa": 0, "sb": 3 }
  }
}
