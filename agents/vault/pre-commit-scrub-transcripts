#!/usr/bin/env bash
# claude-transcripts vault pre-commit hook — Layer 1 of the secret-hygiene system
# (explore-r2iq / explore-76oc OQ-B3) for the TRANSCRIPTS tier + a hard size wall.
# Two gates, both fail-closed on a real hit, best-effort otherwise:
#
#   1. SIZE WALL (defense in depth): if any STAGED blob is >= 100 MiB, block the
#      whole commit. The size guard in transcripts-lib.sh should have chunked it
#      via split-on-copy; if a >=100 MiB blob still reached the index, pushing it
#      would get the ENTIRE push rejected by GitHub and wedge the vault.
#   2. SECRET SCAN (staged content): scan the content being committed. Fast path
#      scans each staged path's on-disk SOURCE (a .partNNN chunk maps back to its
#      base file — scanning the base covers all its chunks); in the automated push
#      (add -> chunk -> commit inside one flock) the on-disk file IS the staged
#      content, so a single batched scrub call avoids 3.7 GB of temp I/O. If a
#      staged path's on-disk source is MISSING (index diverged from disk), that
#      path's STAGED BLOB is materialized and scanned so nothing committed is
#      skipped (scrutiny explore-h04c F3).
#
# NOTE on `--diff-filter=d`: LOWERCASE `d` EXCLUDES deletions (scans Added/Copied/
# Modified/Renamed) — it is NOT "deleted-only" (that is uppercase `D`). Verified
# empirically; a scrutiny reviewer misread it, hence this note.
#
# Body versioned at ~/dotfiles/agents/vault/pre-commit-scrub-transcripts; installed
# by bootstrap-transcripts.sh into ~/.claude/vaults/transcripts.git/hooks/pre-commit.
set -u
SCRUB="${SCRUB:-$HOME/.claude/skills/scrub-secrets/scrub.py}"
WALL="${TS_WALL_BYTES:-104857600}"           # 100 MiB
WORKTREE="${GIT_WORK_TREE:-$HOME/.claude/projects}"

# --- Gate 1: hard size wall over staged blobs -------------------------------
oversize=""
while IFS= read -r -d '' p; do
  sz=$(git cat-file -s ":$p" 2>/dev/null || echo 0)
  [ "$sz" -ge "$WALL" ] && oversize="$oversize$p ($((sz/1048576)) MiB)"$'\n'
done < <(git diff --cached --name-only -z --diff-filter=d 2>/dev/null)
if [ -n "$oversize" ]; then
  {
    echo ""
    echo "BLOCKED: claude-transcripts pre-commit — a staged blob is >= 100 MiB and would"
    echo "be rejected wholesale by GitHub. The split-on-copy size guard should have"
    echo "chunked it; this is the safety wall. Nothing committed. Offending:"
    printf '%s' "$oversize"
  } >&2
  exit 1
fi

# --- Gate 2: secret scan of the content being committed ---------------------
[ -f "$SCRUB" ] || exit 0
command -v python3 >/dev/null 2>&1 || exit 0
tmpd=""; cleanup(){ [ -n "$tmpd" ] && rm -rf "$tmpd"; }; trap cleanup EXIT

declare -A seen=()
files=()
missing=()
while IFS= read -r -d '' p; do
  base="$p"
  case "$p" in *.part[0-9][0-9][0-9]) base="${p%.part[0-9][0-9][0-9]}";; esac
  f="$WORKTREE/$base"
  if [ -f "$f" ]; then
    [ -n "${seen[$base]:-}" ] && continue
    seen[$base]=1
    files+=("$f")
  else
    missing+=("$p")                       # on-disk source gone → scan its staged blob
  fi
done < <(git diff --cached --name-only -z --diff-filter=d 2>/dev/null)

# materialize staged blobs for any path whose on-disk source is absent (normally none)
if [ "${#missing[@]}" -gt 0 ]; then
  tmpd=$(mktemp -d); i=0
  for p in "${missing[@]}"; do
    i=$((i+1)); tf="$tmpd/blob$i"
    if git cat-file -p ":$p" > "$tf" 2>/dev/null; then files+=("$tf"); fi
  done
fi

[ "${#files[@]}" -eq 0 ] && exit 0

if ! python3 "$SCRUB" scan "${files[@]}"; then
  {
    echo ""
    echo "BLOCKED: claude-transcripts pre-commit — a high-confidence secret was found in"
    echo "staged transcript content. Nothing committed. Rotate the credential (it is"
    echo "already on disk / in prior context) and redact the file, then retry."
    echo "(scrub-secrets / explore-r2iq Layer 1)"
  } >&2
  exit 1
fi
exit 0
