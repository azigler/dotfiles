# Template for ~/.config/blightmud/.env.local (the REAL file, never committed)
# Copy to that path and fill in credentials per saved server.
#
#   cp ~/dotfiles/blightmud/.env.local.example ~/.config/blightmud/.env.local
#   chmod 600 ~/.config/blightmud/.env.local
#
# Format: <SERVERNAME>_USER and <SERVERNAME>_PASS, uppercased.
# Each per-game .lua's `login` alias reads these via creds("<game>").

COD_USER=
COD_PASS=

IFMUD_USER=
IFMUD_PASS=

CHATMUD_USER=
CHATMUD_PASS=

CTHULHUMUD_USER=
CTHULHUMUD_PASS=

DW_USER=
DW_PASS=

CF_USER=
CF_PASS=
